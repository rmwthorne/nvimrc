{
  "runtime.version": "LuaJIT",
  "runtime.path": [
    "lua/?.lua",
    "lua/?/init.lua"
  ],
  "diagnostics.globals": ["vim"],
  "workspace.checkThirdParty": true,
  "workspace.library": [
    "$VIMRUNTIME",
    "$HOME/.local/share/nvim/lazy",
    "${3rd}/busted/library",
    "${3rd}/luassert/library",
  ]
}
